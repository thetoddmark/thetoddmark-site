# Remove .html extensions — redirect to clean URLs (fixes Google Search Console canonical issue)
/index.html / 301
/*.html /:splat 301

# Redirect www to non-www (canonical URL enforcement)
https://www.thetoddmark.com/* https://thetoddmark.com/:splat 301!

# Ensure HTTP redirects to HTTPS
http://thetoddmark.com/* https://thetoddmark.com/:splat 301!
http://www.thetoddmark.com/* https://thetoddmark.com/:splat 301!
